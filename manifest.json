{
  "manifest_version": 2,
  "name": "Zotero PaperBridge",
  "version": "0.1.41",
  "description": "Bridge Zotero items, PDFs, and local Markdown reading notes.",
  "author": "PaperBridge",
  "homepage_url": "https://github.com/local/PaperBridge",
  "icons": {
    "16": "icons/paperbridge-16.svg",
    "20": "icons/paperbridge-20.svg",
    "48": "icons/paperbridge-20.svg",
    "96": "icons/paperbridge-20.svg"
  },
  "applications": {
    "zotero": {
      "id": "paperbridge@example.com",
      "update_url": "https://example.com/paperbridge/updates.json",
      "strict_min_version": "6.999",
      "strict_max_version": "11.*"
    }
  }
}
